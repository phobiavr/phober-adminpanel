APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=phober_adminpanel
DB_USERNAME=root
DB_PASSWORD=root

DB_DEVICE_CONNECTION=mysql
DB_DEVICE_HOST=127.0.0.1
DB_DEVICE_PORT=3306
DB_DEVICE_DATABASE=phober_device
DB_DEVICE_USERNAME=root
DB_DEVICE_PASSWORD=root

DB_MEDIA_CONNECTION=mysql
DB_MEDIA_HOST=127.0.0.1
DB_MEDIA_PORT=3306
DB_MEDIA_DATABASE=phober_media
DB_MEDIA_USERNAME=root
DB_MEDIA_PASSWORD=root

DB_CRM_CONNECTION=mysql
DB_CRM_HOST=127.0.0.1
DB_CRM_PORT=3306
DB_CRM_DATABASE=phober_crm
DB_CRM_USERNAME=root
DB_CRM_PASSWORD=root

DB_STAFF_CONNECTION=mysql
DB_STAFF_HOST=127.0.0.1
DB_STAFF_PORT=3306
DB_STAFF_DATABASE=phober_staff
DB_STAFF_USERNAME=root
DB_STAFF_PASSWORD=root

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
