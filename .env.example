APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db_mysql
DB_PORT=3306
DB_DATABASE=phober_adminpanel
DB_USERNAME=root
DB_PASSWORD=root

DB_AUTH_CONNECTION=sqlsrv
DB_AUTH_HOST=db_mssql
DB_AUTH_PORT=1433
DB_AUTH_DATABASE=phober_auth
DB_AUTH_USERNAME=sa
DB_AUTH_PASSWORD=Password1*

DB_DEVICE_CONNECTION=pgsql
DB_DEVICE_HOST=db_postgres
DB_DEVICE_PORT=5432
DB_DEVICE_DATABASE=phober_device
DB_DEVICE_USERNAME=user
DB_DEVICE_PASSWORD=password

DB_CRM_CONNECTION=oracle
DB_CRM_HOST=db_oracle
DB_CRM_PORT=1521
DB_CRM_DATABASE=FREE
DB_CRM_USERNAME=SYSTEM
DB_CRM_PASSWORD=Password1*

DB_STAFF_CONNECTION=sqlsrv
DB_STAFF_HOST=db_mssql
DB_STAFF_PORT=1433
DB_STAFF_DATABASE=phober_staff
DB_STAFF_USERNAME=sa
DB_STAFF_PASSWORD=Password1*

DB_CONFIG_CONNECTION=mysql
DB_CONFIG_HOST=db_mysql
DB_CONFIG_PORT=3306
DB_CONFIG_DATABASE=phober_adminpanel
DB_CONFIG_USERNAME=root
DB_CONFIG_PASSWORD=root

DB_SHARED_CONNECTION=mysql
DB_SHARED_HOST=db_mysql
DB_SHARED_PORT=3306
DB_SHARED_DATABASE=phober_shared
DB_SHARED_USERNAME=root
DB_SHARED_PASSWORD=root

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
